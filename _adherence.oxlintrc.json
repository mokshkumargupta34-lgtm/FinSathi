{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/display/**",
              "components/forms/**",
              "components/text/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|IBM Plex Sans|IBM Plex Sans Devanagari|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, IBM Plex Sans, IBM Plex Sans Devanagari, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrutalButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|textColor|hasBorder|borderColor|hasShadow|shadowColor|radius|children|key|ref|className|style|children)$/]",
        "message": "<BrutalButton> doesn't accept that prop. Declared props: color, textColor, hasBorder, borderColor, hasShadow, shadowColor, radius, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|dark|ghost|link)$/]",
        "message": "<Button> variant must be one of 'light' | 'dark' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeepCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:sheen|radius|children|key|ref|className|style|children)$/]",
        "message": "<DeepCard> doesn't accept that prop. Declared props: sheen, radius, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|subtitle|tint|key|ref|className|style|children)$/]",
        "message": "<GlassBadge> doesn't accept that prop. Declared props: icon, title, subtitle, tint."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassBadge'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:blue|indigo|emerald)$/]",
        "message": "<GlassBadge> tint must be one of 'blue' | 'indigo' | 'emerald'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Label'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Label> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='PasswordInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<PasswordInput> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|strokeWidth|color|metric|label|duration|key|ref|className|style|children)$/]",
        "message": "<ProgressRing> doesn't accept that prop. Declared props: value, size, strokeWidth, color, metric, label, duration."
      },
      {
        "selector": "JSXOpeningElement[name.name='SilverText'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|shadow|uppercase|children|key|ref|className|style|children)$/]",
        "message": "<SilverText> doesn't accept that prop. Declared props: as, shadow, uppercase, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecialText'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|speed|delay|className|inView|once|style|key|ref|className|style|children)$/]",
        "message": "<SpecialText> doesn't accept that prop. Declared props: children, speed, delay, className, inView, once, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Typewriter'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|speed|cursor|loop|deleteSpeed|delay|className|style|key|ref|className|style|children)$/]",
        "message": "<Typewriter> doesn't accept that prop. Declared props: text, speed, cursor, loop, deleteSpeed, delay, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WidgetRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tint|title|subtitle|trailing|children|key|ref|className|style|children)$/]",
        "message": "<WidgetRow> doesn't accept that prop. Declared props: icon, tint, title, subtitle, trailing, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='WidgetRow'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:blue|emerald)$/]",
        "message": "<WidgetRow> tint must be one of 'blue' | 'emerald'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
